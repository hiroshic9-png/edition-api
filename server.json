{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.hiroshic9-png/japan-business-operations",
  "description": "Japan business regulations, compliance, travel, protocols, memory — 10 knowledge domains, 23 tools.",
  "repository": {
    "url": "https://github.com/hiroshic9-png/edition-api",
    "source": "github"
  },
  "version": "0.4.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "edition-mcp-server",
      "version": "0.1.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "EDITION API base URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "EDITION_API_URL"
        },
        {
          "description": "API key for authentication (free beta key provided by default)",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "EDITION_API_KEY"
        }
      ]
    }
  ]
}