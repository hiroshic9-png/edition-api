# Japan Operations Layer MVP — Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider (at least one required for intelligent extraction)
# If both are set, Anthropic (Claude) takes priority
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database (default: SQLite)
# DATABASE_URL=sqlite:///./japan_ops.db
# For production: DATABASE_URL=postgresql://user:pass@host:5432/japan_ops

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data
