# EDITION Intelligence Platform — Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider (at least one required for intelligent extraction)
# Gemini is recommended (set GEMINI_API_KEY)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database (default: SQLite)
# DATABASE_URL=sqlite:///./edition.db
# For production: DATABASE_URL=postgresql://user:pass@host:5432/edition

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./chroma_data
